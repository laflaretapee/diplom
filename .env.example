# Application
APP_ENV=local
APP_NAME=Джейсан
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
API_APP_MODULE=backend.app.main:app
WORKER_APP=backend.app.worker.celery_app
FRONTEND_PORT=5173
VITE_API_BASE_URL=/api
FRONTEND_ORIGIN=http://localhost
VITE_ALLOWED_HOSTS=localhost,127.0.0.1
NGINX_PORT=80

# Backend
DEBUG=true
LOG_LEVEL=info
CORS_ORIGINS=["http://localhost","http://localhost:5173","http://127.0.0.1:5173"]

# Database
POSTGRES_DB=japonica_crm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/japonica_crm

# Redis
REDIS_HOST=redis
REDIS_PORT=6380
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# Storage
STORAGE_BACKEND=local
STORAGE_PATH=/app/storage/private

# JWT
JWT_SECRET_KEY=change-me-access-secret
JWT_REFRESH_SECRET_KEY=change-me-refresh-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
INBOUND_API_KEY=change-me-inbound-api-key

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# AI (proxyapi.ru — OpenAI-compatible proxy)
# AI_BACKEND=qwen_api  — включить для proxyapi.ru
# AI_BACKEND=ollama    — для локальной модели
AI_BACKEND=disabled
QWEN_API_URL=https://api.proxyapi.ru/openai/v1
QWEN_API_KEY=
QWEN_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
AI_TIMEOUT_SECONDS=30

# Security
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
AUTH_RATE_LIMIT_REQUESTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
REFRESH_RATE_LIMIT_REQUESTS=20
REFRESH_RATE_LIMIT_WINDOW_SECONDS=60
INBOUND_RATE_LIMIT_REQUESTS=60
INBOUND_RATE_LIMIT_WINDOW_SECONDS=60
TELEGRAM_LINK_RATE_LIMIT_REQUESTS=10
TELEGRAM_LINK_RATE_LIMIT_WINDOW_SECONDS=300
TELEGRAM_WEBHOOK_RATE_LIMIT_REQUESTS=120
TELEGRAM_WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60

# Production Nginx / TLS
NGINX_SERVER_NAME=crm.example.com
LETSENCRYPT_EMAIL=admin@example.com
